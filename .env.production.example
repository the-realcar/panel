# Production environment template
# Copy values to real environment variables or your secret manager.
# Do not commit real credentials.

APP_ENV=production
BASE_URL=https://panel.example.com
OAUTH_REDIRECT_BASE=https://panel.example.com

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=panel_firmakot
DB_USER=panel_user
DB_PASSWORD=CHANGE_ME

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=mailer@example.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Panel Pracowniczy Firma KOT
MAIL_ENCRYPTION=tls

# Security toggles
SHOW_TEST_CREDENTIALS=false

# Optional OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SCOPE=identify guilds

ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=
ROBLOX_SCOPE=openid profile
